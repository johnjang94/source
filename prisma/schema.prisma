generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  firstName           String?
  lastName            String?
  avatarUrl           String?

  company             Company?

  projectIntakes      ProjectIntake[]
  projectApplications ProjectApplication[]
  projects            Project[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Company {
  id                 String   @id @default(cuid())
  userId             String   @unique
  name               String
  industry           String?
  registeredNumber   String?
  serviceDescription String?
  logoUrl            String?

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model ProjectIntake {
  id                 String    @id @default(cuid())
  clientUserId       String
  projectName        String
  projectDescription String
  expectedOutcome    String
  budgetAllowance    String
  projectDeadline    DateTime
  thumbnailUrl       String?
  videoUrl           String?
  submissionType     String    @default("guided")
  status             String    @default("submitted")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  clientUser         User      @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  project            Project?

  @@index([clientUserId])
}

model Project {
  id                 String               @id @default(cuid())
  intakeId           String               @unique
  clientUserId       String
  projectName        String
  projectDescription String
  expectedOutcome    String
  budgetAllowance    String
  projectDeadline    DateTime
  thumbnailUrl       String?
  videoUrl           String?
  submissionType     String               @default("guided")
  status             String               @default("submitted")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  intake             ProjectIntake        @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  clientUser         User                 @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  applications       ProjectApplication[]

  @@index([clientUserId])
}

model ProjectApplication {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}