generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id
  createdAt           DateTime             @default(now())
  email               String               @unique
  avatarUrl           String?
  companyName         String?
  firstName           String?
  lastName            String?
  projects            Project[]
  projectApplications ProjectApplication[]
  projectIntakes      ProjectIntake[]
}

model ProjectIntake {
  id                 String   @id @default(cuid())
  clientUserId       String
  projectName        String
  timeInvestment     String
  budgetRange        String
  projectDescription String
  goals              String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  mp4Url             String?
  thumbnailUrl       String?
  projects           Project?
  client             User     @relation(fields: [clientUserId], references: [id], onDelete: Cascade)

  @@index([clientUserId])
}

model Project {
  id                 String               @id @default(cuid())
  clientUserId       String
  intakeId           String?              @unique
  projectName        String
  timeInvestment     String
  budgetRange        String
  projectDescription String
  goals              String
  thumbnailUrl       String?
  mp4Url             String?
  status             String               @default("draft")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  client             User                 @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  intake             ProjectIntake?       @relation(fields: [intakeId], references: [id])
  applications       ProjectApplication[]

  @@index([clientUserId])
}

model ProjectApplication {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}
