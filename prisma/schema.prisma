generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  username            String?              @unique
  firstName           String?
  lastName            String?
  avatarUrl           String?

  company             Company?

  projectIntakes      ProjectIntake[]
  projectApplications ProjectApplication[]
  projects            Project[]

  receivedNotifications Notification[] @relation("ReceivedNotifications")
  sentNotifications     Notification[] @relation("SentNotifications")

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Company {
  id                 String   @id @default(cuid())
  userId             String   @unique
  name               String
  industry           String?
  registeredNumber   String?
  serviceDescription String?
  logoUrl            String?

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model ProjectIntake {
  id                 String    @id @default(cuid())
  clientUserId       String
  projectName        String
  projectDescription String
  expectedOutcome    String
  budgetAllowance    String
  projectDeadline    DateTime
  thumbnailUrl       String?
  videoUrl           String?
  submissionType     String    @default("guided")
  position           String?   @default("Project Coordinator")
  status             String    @default("submitted")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  clientUser         User      @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  project            Project?

  @@index([clientUserId])
}

model Project {
  id                 String               @id @default(cuid())
  intakeId           String               @unique
  clientUserId       String
  projectName        String
  projectDescription String
  expectedOutcome    String
  budgetAllowance    String
  projectDeadline    DateTime
  thumbnailUrl       String?
  videoUrl           String?
  submissionType     String               @default("guided")
  position           String?              @default("Project Coordinator")
  status             String               @default("submitted")
  viewCount          Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  intake             ProjectIntake        @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  clientUser         User                 @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  applications       ProjectApplication[]
  notifications      Notification[]

  @@index([clientUserId])
}

model ProjectApplication {
  id          String            @id @default(cuid())
  projectId   String
  userId      String
  status      ApplicationStatus @default(APPLIED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  form        ApplicationForm?

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ApplicationForm {
  id              String             @id @default(cuid())
  applicationId   String             @unique
  firstName       String
  lastName        String
  email           String
  position        String
  resumeR2Key     String
  portfolioLink   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  application     ProjectApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  senderId    String?
  projectId   String?
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  recipient   User     @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      User?    @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([recipientId, isRead])
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  SELECTED
  REJECTED
}